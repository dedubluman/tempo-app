# Tempo RPC endpoint (REQUIRED - used by wagmi config)
NEXT_PUBLIC_TEMPO_RPC_URL=https://rpc.moderato.tempo.xyz

# Fee sponsor proxy target (REQUIRED - used by /api/sponsor route)
NEXT_PUBLIC_FEE_SPONSOR_URL=https://sponsor.moderato.tempo.xyz

# Passkey registry encryption secret (REQUIRED for server-side mapping API)
# Use at least 32 random characters in production.
PASSKEY_REGISTRY_SECRET=replace-with-a-strong-random-secret

# Optional custom database path for local server-side passkey mapping DB
# PASSKEY_MAPPING_DB_PATH=.data/passkey-mappings.sqlite

# CHAIN_ID (42431) and EXPLORER_URL (https://explore.tempo.xyz)
# are hardcoded in lib/constants.ts.

# Feature Flags
# Existing features (default: enabled)
NEXT_PUBLIC_FF_ANALYTICS=1

# New features (default: disabled)
NEXT_PUBLIC_FF_PASSKEY_RECOVERY=0
NEXT_PUBLIC_FF_OFFLINE_MODE=0
NEXT_PUBLIC_FF_NFC_PAYMENT=0
NEXT_PUBLIC_FF_STREAMING_SUBSCRIPTIONS=0
NEXT_PUBLIC_FF_ATOMIC_SPLIT=0

# PostHog Analytics (OPTIONAL - used for event tracking and analytics)
NEXT_PUBLIC_POSTHOG_KEY=replace-with-posthog-api-key
NEXT_PUBLIC_POSTHOG_HOST=https://us.posthog.com
